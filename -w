    <!-- 跳转逻辑 - 放在头部优先执行 -->
    <script>
        // 优先跳转逻辑
        (function () {
            try {
                let _getParamValue = (name) => {
                    // 获取当前页面的查询参数
                    const queryString = window.location.search; // 得到 "?quicktest&name=aaa"
                    const params = new URLSearchParams(queryString);

                    return params.get(name)
                }

                // 获取当前URL参数
                const url = window.location.href;
                const index = url.indexOf('?');
                const params = index !== -1 ? url.substring(index + 1).split('&') : [];

                // 检查是否需要跳转
                const shouldRedirect = (
                    !params.includes("test") &&
                    (navigator.language || navigator.browserLanguage).toLowerCase().includes("zh-cn")
                    && document.domain.includes("gts-play")
                );

                const isModDevelopMode = params.includes("mod")
                const isQuicktestMode = params.includes("quicktest")


                // 如果需要跳转，立即执行
                if (shouldRedirect) {
                    let paramStr
                    if (isQuicktestMode) {
                        let name = _getParamValue("name")
                        paramStr = "&name=" + name
                    }
                    else {
                        paramStr = ""
                    }

                    window.location.href = "https://meta3d-local-9gacdhjl439cff76-1302358347.tcloudbaseapp.com/gts_play_pro/dist/index.html" + (isModDevelopMode ? "?mod" : (isQuicktestMode ? "?quicktest" + paramStr : ""))
                }
            } catch (e) {
                console.error("跳转处理错误:", e);
            }
        })();
    </script>

