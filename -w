    <script>
        let getActualWidth = () => {
            // return document.documentElement.clientWidth
            return window.innerWidth || document.documentElement.clientWidth
        }

        let getActualHeight = () => {
            // return document.documentElement.clientHeight
            return window.innerHeight || document.documentElement.clientHeight
        }


        let checkOrientationIsHorrizon = () => {
            if (typeof window.orientation !== 'undefined') {
                if (window.orientation === 90 || window.orientation === -90) {
                    return true
                } else {
                    return false
                }
            } else {
                return null; // 不支持window.orientation
            }
        }

        let isMobile = () => {
            return !!window.navigator.userAgent.match(/(phone|pad|pod|iPhone|iPod|ios|iPad|Android|Mobile|BlackBerry|IEMobile|MQQBrowser|JUC|Fennec|wOSBrowser|BrowserNG|WebOS|Symbian|Windows Phone)/i)
        }


        let isNeedHandleLandscape = () => {
            let isHorrizon = checkOrientationIsHorrizon()

            if (!isMobile() || isHorrizon == null) {
                return getActualWidth() <= getActualHeight()
            }

            return !isHorrizon
        }


        let rotateDom = (targetDom) => {
            let width = getActualWidth()
            let height = getActualHeight()

            targetDom.style.position = 'absolute';
            targetDom.style.width = `${height}px`;
            targetDom.style.height = `${width}px`;
            targetDom.style.left = `${0 - (height - width) / 2}px`;
            targetDom.style.top = `${(height - width) / 2}px`;
            targetDom.style.transform = 'rotate(90deg)';
            targetDom.style.transformOrigin = '50% 50%';
        }

